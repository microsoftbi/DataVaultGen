USE [{{ psa_db_name }}]
GO

{% for table in tables %}
IF EXISTS (SELECT * FROM sys.views WHERE name = 'V_{{ table.object_name }}_MTA' AND schema_id = SCHEMA_ID('{{ table.schema_name }}'))
    DROP VIEW [{{ table.schema_name }}].[V_{{ table.object_name }}_MTA]
GO
CREATE VIEW [{{ table.schema_name }}].[V_{{ table.object_name }}_MTA]
AS
SELECT
    CONVERT(CHAR(32), HASHBYTES('MD5',
        {% set key_fields = table.pk_fields + table.bk_fields %}
        {% for f in key_fields %}
        ISNULL(TRIM(CONVERT(NVARCHAR(255), [{{ f.field_name }}])), N'') + N'{{ hash_dummy }}'
        {% if not loop.last %} + {% endif %}
        {% endfor %}
    ), 2) AS HK,
    GETDATE() AS LOAD_DTS,
    '{{ table.record_source }}' AS REC_SRC,
    {% for f in table.pk_fields %}
    [{{ f.field_name }}],
    {% endfor %}
    {% for f in table.bk_fields %}
    [{{ f.field_name }}],
    {% endfor %}
    {% for f in table.di_fields %}
    [{{ f.field_name }}]{% if not loop.last %},{% endif %}
    {% endfor %}
FROM [{{ table.schema_name }}].[{{ table.object_name }}_STG]
GO

{% endfor %}